<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  name="LISTAGEM_PACIENTES"
  pageWidth="842"
  pageHeight="595"
  orientation="Landscape"
  columnWidth="802"
  leftMargin="20"
  rightMargin="20"
  topMargin="20"
  bottomMargin="20">

  <parameter name="idpaziente" class="java.lang.String"/>

  <queryString>
    <![CDATA[
      SELECT
        idpaziente,
        idpazienteesterno,
        nome,
        cognome,
        sesso,
        datanascita,
        codicefiscale,
        nomecomuneresidenza,
        capcomuneresidenza,
        indirizzoresidenza,
        civicoresidenza,
        idprovinciaresidenza,
        telefono,
        cellulare,
        email,
        dataaggiornamento
      FROM hero.paziente
      WHERE 1=1
        AND (
          $P{idpaziente} IS NULL
          OR CAST($P{idpaziente} AS VARCHAR) = ''
          OR idpaziente = $P{idpaziente}
        )
      ORDER BY nome ASC
    ]]>
  </queryString>

  <field name="idpaziente" class="java.lang.String"/>
  <field name="idpazienteesterno" class="java.lang.String"/>
  <field name="nome" class="java.lang.String"/>
  <field name="cognome" class="java.lang.String"/>
  <field name="sesso" class="java.lang.String"/>
  <field name="datanascita" class="java.sql.Date"/>
  <field name="codicefiscale" class="java.lang.String"/>
  <field name="nomecomuneresidenza" class="java.lang.String"/>
  <field name="capcomuneresidenza" class="java.lang.String"/>
  <field name="indirizzoresidenza" class="java.lang.String"/>
  <field name="civicoresidenza" class="java.lang.String"/>
  <field name="idprovinciaresidenza" class="java.lang.String"/>
  <field name="telefono" class="java.lang.String"/>
  <field name="cellulare" class="java.lang.String"/>
  <field name="email" class="java.lang.String"/>
  <field name="dataaggiornamento" class="java.util.Date"/>

  <title>
    <band height="52">
      <staticText>
        <reportElement x="0" y="0" width="802" height="20"/>
        <textElement>
          <font fontName="DejaVu Sans" size="14" isBold="true"/>
        </textElement>
        <text>LISTAGEM GERAL DE PACIENTES</text>
      </staticText>

      <textField>
        <reportElement x="0" y="24" width="802" height="12"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA["Filtro idpaziente: " + ($P{idpaziente} == null || $P{idpaziente}.trim().isEmpty() ? "(todos)" : $P{idpaziente})]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="38" width="802" height="12"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8"/>
        </textElement>
        <text>Ordenação: nome (ASC)</text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="14">
      <rectangle>
        <reportElement mode="Opaque" x="0" y="0" width="802" height="14" backcolor="#F0F0F0"/>
        <graphicElement>
          <pen lineWidth="0.0"/>
        </graphicElement>
      </rectangle>
      <line>
        <reportElement x="0" y="0" width="802" height="1"/>
        <graphicElement><pen lineWidth="0.3"/></graphicElement>
      </line>
      <line>
        <reportElement x="0" y="13" width="802" height="1"/>
        <graphicElement><pen lineWidth="0.3"/></graphicElement>
      </line>
      <staticText><reportElement x="0" y="0" width="44" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>ID</text></staticText>
      <staticText><reportElement x="44" y="0" width="48" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>ID Ext.</text></staticText>
      <staticText><reportElement x="92" y="0" width="140" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Nome</text></staticText>
      <staticText><reportElement x="232" y="0" width="22" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Sexo</text></staticText>
      <staticText><reportElement x="254" y="0" width="44" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Nasc.</text></staticText>
      <staticText><reportElement x="298" y="0" width="60" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>CPF</text></staticText>
      <staticText><reportElement x="358" y="0" width="58" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Município</text></staticText>
      <staticText><reportElement x="416" y="0" width="30" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>CEP</text></staticText>
      <staticText><reportElement x="446" y="0" width="76" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Endereço</text></staticText>
      <staticText><reportElement x="522" y="0" width="24" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Nº</text></staticText>
      <staticText><reportElement x="546" y="0" width="28" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>ID Prov.</text></staticText>
      <staticText><reportElement x="574" y="0" width="46" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Telefone</text></staticText>
      <staticText><reportElement x="620" y="0" width="50" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Celular</text></staticText>
      <staticText><reportElement x="670" y="0" width="88" height="14" backcolor="#E0E0E0"/><textElement><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>E-mail</text></staticText>
      <staticText><reportElement x="758" y="0" width="44" height="14" backcolor="#E0E0E0"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6" isBold="true"/></textElement><text>Atualiz.</text></staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="18">
      <textField isStretchWithOverflow="true"><reportElement x="0" y="0" width="44" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{idpaziente}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="44" y="0" width="48" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{idpazienteesterno}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="92" y="0" width="140" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{nome} == null ? ($F{cognome} == null ? "" : $F{cognome}) : ($F{cognome} == null || $F{cognome}.trim().isEmpty() ? $F{nome} : $F{nome} + " " + $F{cognome})]]></textFieldExpression></textField>
      <textField><reportElement x="232" y="0" width="22" height="18"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{sesso}]]></textFieldExpression></textField>
      <textField pattern="dd/MM/yyyy"><reportElement x="254" y="0" width="44" height="18"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{datanascita}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="298" y="0" width="60" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{codicefiscale}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="358" y="0" width="58" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{nomecomuneresidenza}]]></textFieldExpression></textField>
      <textField><reportElement x="416" y="0" width="30" height="18"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{capcomuneresidenza}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="446" y="0" width="76" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{indirizzoresidenza}]]></textFieldExpression></textField>
      <textField><reportElement x="522" y="0" width="24" height="18"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{civicoresidenza}]]></textFieldExpression></textField>
      <textField><reportElement x="546" y="0" width="28" height="18"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{idprovinciaresidenza}]]></textFieldExpression></textField>
      <textField><reportElement x="574" y="0" width="46" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{telefono}]]></textFieldExpression></textField>
      <textField><reportElement x="620" y="0" width="50" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{cellulare}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="670" y="0" width="88" height="18"/><textElement><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{email}]]></textFieldExpression></textField>
      <textField pattern="dd/MM/yyyy HH:mm"><reportElement x="758" y="0" width="44" height="18"/><textElement textAlignment="Center"><font fontName="DejaVu Sans" size="6"/></textElement><textFieldExpression><![CDATA[$F{dataaggiornamento}]]></textFieldExpression></textField>
    </band>
  </detail>

  <pageFooter>
    <band height="24">
      <line>
        <reportElement x="0" y="0" width="802" height="1"/>
        <graphicElement><pen lineWidth="0.3"/></graphicElement>
      </line>

      <textField>
        <reportElement x="0" y="6" width="320" height="14"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA["Total de Registros: " + $V{REPORT_COUNT}]]></textFieldExpression>
      </textField>

      <textField>
        <reportElement x="690" y="6" width="112" height="14"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>

</jasperReport>
