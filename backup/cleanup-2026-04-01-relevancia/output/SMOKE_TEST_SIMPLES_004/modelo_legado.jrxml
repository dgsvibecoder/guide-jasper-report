<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="MODELO_VENDAS" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="40" bottomMargin="40">
	<queryString>
		<![CDATA[
			SELECT data, item_nome, valor_total 
			FROM view_vendas_diarias
			WHERE 1=1
			ORDER BY data DESC
		]]>
	</queryString>
	<field name="data" class="java.sql.Date"/>
	<field name="item_nome" class="java.lang.String"/>
	<field name="valor_total" class="java.math.BigDecimal"/>
	<title>
		<band height="40">
			<staticText>
				<reportElement x="0" y="0" width="515" height="40"/>
				<textElement textAlignment="Center"><font fontName="DejaVu Sans" size="14" isBold="true"/></textElement>
				<text><![CDATA[MODELO LEGADO - Vendas]]></text>
			</staticText>
		</band>
	</title>
	<columnHeader>
		<band height="20">
			<staticText>
				<reportElement x="0" y="0" width="515" height="20"/>
				<textElement textAlignment="Center"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
				<text><![CDATA[Dados do Modelo]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="18">
		</band>
	</detail>
	<pageFooter>
		<band height="25">
		</band>
	</pageFooter>
</jasperReport>
