<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="SMOKE_DETAIL_001"
  pageWidth="515" pageHeight="842"
  columnWidth="515"
  leftMargin="0" rightMargin="0"
  topMargin="0" bottomMargin="0">

  <parameter name="pacienteId" class="java.lang.String"/>

  <queryString>
    <![CDATA[
      SELECT
        paciente_id,
        data_atendimento,
        procedimento_descricao,
        valor_procedimento
      FROM view_pacientes_atendidos
      WHERE 1=1
        AND paciente_id = $P{pacienteId}
      ORDER BY data_atendimento DESC
    ]]>
  </queryString>

  <field name="paciente_id" class="java.lang.Integer"/>
  <field name="data_atendimento" class="java.sql.Date"/>
  <field name="procedimento_descricao" class="java.lang.String"/>
  <field name="valor_procedimento" class="java.math.BigDecimal"/>

  <title>
    <band height="20">
      <staticText>
        <reportElement x="0" y="0" width="515" height="15"/>
        <text><![CDATA[Atendimentos do Paciente]]></text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="20">
      <staticText>
        <reportElement x="0" y="0" width="130" height="15"/>
        <text><![CDATA[Data]]></text>
      </staticText>
      <staticText>
        <reportElement x="130" y="0" width="255" height="15"/>
        <text><![CDATA[Procedimento]]></text>
      </staticText>
      <staticText>
        <reportElement x="385" y="0" width="130" height="15"/>
        <text><![CDATA[Valor R$]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <textField>
        <reportElement x="0" y="0" width="130" height="15"/>
        <textFieldExpression>$F{data_atendimento}</textFieldExpression>
      </textField>
      <textField>
        <reportElement x="130" y="0" width="255" height="15"/>
        <textFieldExpression>$F{procedimento_descricao}</textFieldExpression>
      </textField>
      <textField pattern="#,##0.00">
        <reportElement x="385" y="0" width="130" height="15"/>
        <textFieldExpression>$F{valor_procedimento}</textFieldExpression>
      </textField>
    </band>
  </detail>

  <pageFooter>
    <band height="15">
      <staticText>
        <reportElement x="0" y="0" width="515" height="15"/>
        <text><![CDATA[]]></text>
      </staticText>
    </band>
  </pageFooter>

</jasperReport>
