<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="SMOKE_MASTER_001"
  pageWidth="595" pageHeight="842"
  columnWidth="515"
  leftMargin="40" rightMargin="40"
  topMargin="40" bottomMargin="40">

  <parameter name="dataInicio" class="java.util.Date"/>
  <parameter name="dataFim" class="java.util.Date"/>
  <parameter name="SUBREPORT_DETAIL_PATH" class="java.lang.String"/>

  <queryString>
    <![CDATA[
      SELECT
        idaccesso,
        idpaziente,
        nomeazienda,
        datainserimento
      FROM accessops
      WHERE 1=1
        AND ($P{dataInicio} IS NULL OR datainserimento >= $P{dataInicio})
        AND ($P{dataFim} IS NULL OR datainserimento <= $P{dataFim})
      ORDER BY datainserimento DESC
    ]]>
  </queryString>

  <field name="idaccesso" class="java.lang.String"/>
  <field name="idpaziente" class="java.lang.String"/>
  <field name="nomeazienda" class="java.lang.String"/>
  <field name="datainserimento" class="java.util.Date"/>

  <title>
    <band height="60">
      <staticText>
        <reportElement x="0" y="10" width="515" height="30"/>
        <text><![CDATA[Acessos com Eventos Médicos]]></text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="25">
      <staticText>
        <reportElement x="0" y="0" width="130" height="20"/>
        <text><![CDATA[ID Acesso]]></text>
      </staticText>
      <staticText>
        <reportElement x="130" y="0" width="130" height="20"/>
        <text><![CDATA[ID Paciente]]></text>
      </staticText>
      <staticText>
        <reportElement x="260" y="0" width="255" height="20"/>
        <text><![CDATA[Empresa]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="60">
      <textField>
        <reportElement x="0" y="0" width="130" height="20"/>
        <textFieldExpression>$F{idaccesso}</textFieldExpression>
      </textField>
      <textField>
        <reportElement x="130" y="0" width="130" height="20"/>
        <textFieldExpression>$F{idpaziente}</textFieldExpression>
      </textField>
      <textField>
        <reportElement x="260" y="0" width="255" height="20"/>
        <textFieldExpression>$F{nomeazienda}</textFieldExpression>
      </textField>
      <subreport>
        <reportElement x="0" y="25" width="515" height="30"/>
        <subreportParameter name="pacienteId">
          <subreportParameterExpression><![CDATA[$F{idpaziente}]]></subreportParameterExpression>
        </subreportParameter>
        <subreportExpression><![CDATA[$P{SUBREPORT_DETAIL_PATH}]]></subreportExpression>
      </subreport>
    </band>
  </detail>

  <pageFooter>
    <band height="30">
      <staticText>
        <reportElement x="0" y="5" width="515" height="20"/>
        <text><![CDATA[Página $V{PAGE_NUMBER}]]></text>
      </staticText>
    </band>
  </pageFooter>

</jasperReport>
