<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="SMOKE_TEST_SIMPLES_003_BAD" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="40" bottomMargin="40">
	<queryString>
		<![CDATA[
			SELECT data, item_nome, valor_total 
			FROM view_vendas_diarias
			WHERE 1=1
			ORDER BY data DESC
		]]>
	</queryString>
	<field name="data" class="java.lang.Integer"/>
	<field name="item_nome" class="java.lang.String"/>
	<field name="valor_total" class="java.math.BigDecimal"/>
	<title>
		<band height="40">
			<staticText>
				<reportElement x="0" y="0" width="515" height="40"/>
				<textElement textAlignment="Center"><font fontName="DejaVu Sans" size="14" isBold="true"/></textElement>
				<text><![CDATA[SMOKE TEST 003 - Type Mismatch (BAD)]]></text>
			</staticText>
		</band>
	</title>
	<columnHeader>
		<band height="20">
			<staticText>
				<reportElement x="0" y="0" width="515" height="20"/>
				<box><topPen lineWidth="1.0"/><leftPen lineWidth="1.0"/><bottomPen lineWidth="1.0"/><rightPen lineWidth="1.0"/></box>
				<textElement textAlignment="Center"><font fontName="DejaVu Sans" size="9" isBold="true"/></textElement>
				<text><![CDATA[Expected Type Mismatch: 'data' declared as Integer but view returns Date]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="18">
			<textField>
				<reportElement x="0" y="0" width="515" height="18"/>
				<textElement><font fontName="DejaVu Sans" size="8"/></textElement>
				<textFieldExpression><![CDATA[$F{data}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band height="25">
		</band>
	</pageFooter>
</jasperReport>
