<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="SMOKE_TEST_SIMPLES_005_ACCESSOPS"
  pageWidth="595" pageHeight="842"
  columnWidth="515"
  leftMargin="40" rightMargin="40"
  topMargin="40" bottomMargin="40">

  <queryString>
    <![CDATA[
      SELECT
        idaccesso,
        idpaziente,
        nomeazienda,
        datainserimento
      FROM accessops
      WHERE 1=1
      ORDER BY datainserimento DESC
    ]]>
  </queryString>

  <field name="idaccesso" class="java.lang.String"/>
  <field name="idpaziente" class="java.lang.String"/>
  <field name="nomeazienda" class="java.lang.String"/>
  <field name="datainserimento" class="java.util.Date"/>

  <title>
    <band height="40">
      <staticText>
        <reportElement x="0" y="8" width="515" height="24"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="12" isBold="true"/>
        </textElement>
        <text><![CDATA[SMOKE TEST SIMPLES 005 - ACCESSOPS]]></text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="20">
      <staticText>
        <reportElement x="0" y="0" width="90" height="18"/>
        <textElement><font fontName="DejaVu Sans" size="8" isBold="true"/></textElement>
        <text><![CDATA[ID Acesso]]></text>
      </staticText>
      <staticText>
        <reportElement x="90" y="0" width="100" height="18"/>
        <textElement><font fontName="DejaVu Sans" size="8" isBold="true"/></textElement>
        <text><![CDATA[ID Paciente]]></text>
      </staticText>
      <staticText>
        <reportElement x="190" y="0" width="205" height="18"/>
        <textElement><font fontName="DejaVu Sans" size="8" isBold="true"/></textElement>
        <text><![CDATA[Empresa]]></text>
      </staticText>
      <staticText>
        <reportElement x="395" y="0" width="120" height="18"/>
        <textElement><font fontName="DejaVu Sans" size="8" isBold="true"/></textElement>
        <text><![CDATA[Data Inserimento]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="18">
      <textField>
        <reportElement x="0" y="0" width="90" height="16"/>
        <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{idaccesso}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="90" y="0" width="100" height="16"/>
        <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{idpaziente}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="190" y="0" width="205" height="16"/>
        <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{nomeazienda}]]></textFieldExpression>
      </textField>
      <textField pattern="dd/MM/yyyy HH:mm">
        <reportElement x="395" y="0" width="120" height="16"/>
        <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{datainserimento}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <pageFooter>
    <band height="20">
      <textField>
        <reportElement x="450" y="2" width="65" height="14"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>

</jasperReport>
