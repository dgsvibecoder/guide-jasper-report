<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="PAZIENTE_ALLERGIA_MASTER"
  pageWidth="842" pageHeight="595"
  orientation="Landscape"
  columnWidth="762"
  leftMargin="40" rightMargin="40"
  topMargin="30" bottomMargin="30">

  <parameter name="idpaziente" class="java.lang.String"/>
  <parameter name="SUBREPORT_DETAIL_PATH" class="java.lang.String"/>

  <queryString>
    <![CDATA[
      SELECT
        p.idpaziente,
        p.idpazienteesterno,
        p.cognome,
        p.nome,
        p.personagiuridica,
        p.sesso,
        p.idcomunenascita,
        p.nomecomunenascita
      FROM paziente p
      WHERE 1=1
        AND ($P{idpaziente} IS NULL OR p.idpaziente = $P{idpaziente})
        AND EXISTS (
          SELECT 1
          FROM allergia a
          WHERE a.idpaziente = p.idpaziente
        )
      ORDER BY p.cognome, p.nome
    ]]>
  </queryString>

  <field name="idpaziente" class="java.lang.String"/>
  <field name="idpazienteesterno" class="java.lang.String"/>
  <field name="cognome" class="java.lang.String"/>
  <field name="nome" class="java.lang.String"/>
  <field name="personagiuridica" class="java.lang.String"/>
  <field name="sesso" class="java.lang.String"/>
  <field name="idcomunenascita" class="java.lang.String"/>
  <field name="nomecomunenascita" class="java.lang.String"/>

  <title>
    <band height="48">
      <staticText>
        <reportElement x="0" y="5" width="762" height="24"/>
        <textElement>
          <font size="16" isBold="true" fontName="DejaVu Sans"/>
        </textElement>
        <text><![CDATA[PAZIENTE_ALLERGIA]]></text>
      </staticText>
      <staticText>
        <reportElement x="0" y="29" width="762" height="16"/>
        <text><![CDATA[Relatorio de paciente com alergias para apoio a prescricao medica]]></text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="24">
      <line>
        <reportElement x="0" y="0" width="762" height="1"/>
      </line>
      <line>
        <reportElement x="0" y="23" width="762" height="1"/>
      </line>
      <staticText>
        <reportElement x="0" y="4" width="90" height="16"/>
        <text><![CDATA[ID Paziente]]></text>
      </staticText>
      <staticText>
        <reportElement x="90" y="4" width="92" height="16"/>
        <text><![CDATA[ID Esterno]]></text>
      </staticText>
      <staticText>
        <reportElement x="182" y="4" width="120" height="16"/>
        <text><![CDATA[Cognome]]></text>
      </staticText>
      <staticText>
        <reportElement x="302" y="4" width="110" height="16"/>
        <text><![CDATA[Nome]]></text>
      </staticText>
      <staticText>
        <reportElement x="412" y="4" width="70" height="16"/>
        <text><![CDATA[P. Giur.]]></text>
      </staticText>
      <staticText>
        <reportElement x="482" y="4" width="45" height="16"/>
        <text><![CDATA[Sesso]]></text>
      </staticText>
      <staticText>
        <reportElement x="527" y="4" width="95" height="16"/>
        <text><![CDATA[ID Comune Nasc.]]></text>
      </staticText>
      <staticText>
        <reportElement x="622" y="4" width="140" height="16"/>
        <text><![CDATA[Comune Nascita]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="96">
      <rectangle>
        <reportElement x="0" y="0" width="762" height="22" mode="Opaque" backcolor="#F4F7FB">
          <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
        </reportElement>
      </rectangle>

      <textField>
        <reportElement x="0" y="4" width="90" height="16"/>
        <textFieldExpression><![CDATA[$F{idpaziente}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="90" y="4" width="92" height="16"/>
        <textFieldExpression><![CDATA[$F{idpazienteesterno}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="182" y="4" width="120" height="16"/>
        <textFieldExpression><![CDATA[$F{cognome}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="302" y="4" width="110" height="16"/>
        <textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="412" y="4" width="70" height="16"/>
        <textFieldExpression><![CDATA[$F{personagiuridica}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="482" y="4" width="45" height="16"/>
        <textFieldExpression><![CDATA[$F{sesso}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="527" y="4" width="95" height="16"/>
        <textFieldExpression><![CDATA[$F{idcomunenascita}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="622" y="4" width="140" height="16"/>
        <textFieldExpression><![CDATA[$F{nomecomunenascita}]]></textFieldExpression>
      </textField>

      <subreport>
        <reportElement x="0" y="28" width="762" height="64"/>
        <subreportParameter name="pacienteId">
          <subreportParameterExpression><![CDATA[$F{idpaziente}]]></subreportParameterExpression>
        </subreportParameter>
        <connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
        <subreportExpression><![CDATA[$P{SUBREPORT_DETAIL_PATH}]]></subreportExpression>
      </subreport>
    </band>
  </detail>

  <pageFooter>
    <band height="20">
      <textField>
        <reportElement x="0" y="2" width="762" height="16"/>
        <textFieldExpression><![CDATA["Pagina " + $V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>

</jasperReport>
