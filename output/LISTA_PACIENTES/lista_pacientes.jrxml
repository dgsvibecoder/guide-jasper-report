<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    name="LISTA_PACIENTES"
    pageWidth="842"
    pageHeight="595"
    orientation="Landscape"
    columnWidth="762"
    leftMargin="40"
    rightMargin="40"
    topMargin="40"
    bottomMargin="40">

    <parameter name="dataInicio" class="java.sql.Timestamp" isForPrompting="false">
        <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
    </parameter>
    <parameter name="dataFim" class="java.sql.Timestamp" isForPrompting="false">
        <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
    </parameter>

    <queryString>
    <![CDATA[
      SELECT
        p.idpaziente,
        p.idpazienteesterno,
        p.nome,
        p.cognome,
        p.datainserimento,
        p.sesso,
        p.telefono,
        p.cellulare,
        p.email
            FROM hero.paziente p
            WHERE 1=1
            AND p.datainserimento >= COALESCE(CAST($P{dataInicio} AS TIMESTAMP), p.datainserimento)
            AND p.datainserimento <= COALESCE(CAST($P{dataFim} AS TIMESTAMP), p.datainserimento)
            ORDER BY p.datainserimento ASC
    ]]>
  </queryString>

    <field name="idpaziente" class="java.lang.String" />
    <field name="idpazienteesterno" class="java.lang.String" />
    <field name="nome" class="java.lang.String" />
    <field name="cognome" class="java.lang.String" />
    <field name="datainserimento" class="java.sql.Timestamp" />
    <field name="sesso" class="java.lang.String" />
    <field name="telefono" class="java.lang.String" />
    <field name="cellulare" class="java.lang.String" />
    <field name="email" class="java.lang.String" />

    <variable name="totalRegistros" class="java.lang.Integer" calculation="Count" resetType="Report">
        <variableExpression><![CDATA[$F{idpaziente}]]></variableExpression>
    </variable>

    <title>
        <band height="66">
            <rectangle>
                <reportElement x="0" y="0" width="762" height="66" backcolor="#0B3954" />
            </rectangle>

            <staticText>
                <reportElement x="8" y="6" width="500" height="24" forecolor="#FFFFFF" />
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="16" isBold="true" />
                </textElement>
                <text>LISTA DE PACIENTES - OPERACIONAL DIARIO</text>
            </staticText>

            <textField>
                <reportElement x="8" y="33" width="500" height="14" forecolor="#FFFFFF" />
                <textElement>
                    <font fontName="DejaVu Sans" size="9" />
                </textElement>
                <textFieldExpression><![CDATA[
          "Periodo: "
          + ($P{dataInicio} == null ? "Inicio aberto" : new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{dataInicio}))
          + " ate "
          + ($P{dataFim} == null ? "Fim aberto" : new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{dataFim}))
        ]]></textFieldExpression>
            </textField>

            <textField evaluationTime="Report">
                <reportElement x="520" y="33" width="234" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Right">
                    <font fontName="DejaVu Sans" size="9" isBold="true" />
                </textElement>
                <textFieldExpression><![CDATA["Total de registros: " + $V{totalRegistros}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement x="0" y="0" width="762" height="24" backcolor="#1F4E79" />
            </rectangle>

            <staticText>
                <reportElement x="2" y="5" width="90" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>ID Paciente</text>
            </staticText>
            <staticText>
                <reportElement x="94" y="5" width="100" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>ID Externo</text>
            </staticText>
            <staticText>
                <reportElement x="196" y="5" width="180" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Left">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>Nome Paciente</text>
            </staticText>
            <staticText>
                <reportElement x="378" y="5" width="44" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>Sexo</text>
            </staticText>
            <staticText>
                <reportElement x="424" y="5" width="98" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>Telefone</text>
            </staticText>
            <staticText>
                <reportElement x="524" y="5" width="98" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>Cellulare</text>
            </staticText>
            <staticText>
                <reportElement x="624" y="5" width="136" height="14" forecolor="#FFFFFF" />
                <textElement textAlignment="Left">
                    <font fontName="DejaVu Sans" size="8" isBold="true" />
                </textElement>
                <text>Email</text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <rectangle>
                <reportElement x="0" y="0" width="762" height="18" backcolor="#F4F9FC">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT}.intValue() % 2 == 0]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="0" width="762" height="18" backcolor="#EAF2F8">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT}.intValue() % 2 != 0]]></printWhenExpression>
                </reportElement>
            </rectangle>

            <textField>
                <reportElement x="2" y="2" width="90" height="14" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$F{idpaziente}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="94" y="2" width="100" height="14" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$F{idpazienteesterno}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="196" y="2" width="180" height="14" />
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[(($F{nome} == null ? "" : $F{nome}) + " " + ($F{cognome} == null ? "" : $F{cognome})).trim()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="378" y="2" width="44" height="14" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$F{sesso}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="424" y="2" width="98" height="14" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$F{telefono}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="524" y="2" width="98" height="14" />
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$F{cellulare}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="624" y="2" width="136" height="14" />
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="22">
            <line>
                <reportElement x="0" y="0" width="762" height="1" forecolor="#B9C6D3" />
            </line>

            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="2" y="7" width="200" height="12" />
                <textElement>
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="612" y="7" width="74" height="12" />
                <textElement textAlignment="Right">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <text>Pagina</text>
            </staticText>
            <textField>
                <reportElement x="688" y="7" width="22" height="12" />
                <textElement textAlignment="Right">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="712" y="7" width="14" height="12" />
                <textElement textAlignment="Center">
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <text>de</text>
            </staticText>
            <textField>
                <reportElement x="728" y="7" width="30" height="12" />
                <textElement>
                    <font fontName="DejaVu Sans" size="7" />
                </textElement>
                <textFieldExpression><![CDATA[$V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>