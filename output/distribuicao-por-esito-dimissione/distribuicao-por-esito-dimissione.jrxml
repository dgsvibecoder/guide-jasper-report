<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  name="DISTRIBUICAO_ESITO_DIMISSIONE"
  pageWidth="595"
  pageHeight="842"
  orientation="Portrait"
  columnWidth="515"
  leftMargin="40"
  rightMargin="40"
  topMargin="40"
  bottomMargin="40">

  <parameter name="data_inizio" class="java.sql.Date"/>
  <parameter name="data_fim" class="java.sql.Date"/>
  <parameter name="categoria_esito" class="java.lang.String"/>

  <queryString>
    <![CDATA[
      SELECT
        nomeesitodimissione,
        codmesitodimissione,
        categoriaesitodimissione,
        COUNT(*) AS qtde
      FROM accessops
      WHERE 1=1
        AND datadimissione IS NOT NULL
        AND (
          $P{data_inizio} IS NULL
          OR DATE(datadimissione) >= $P{data_inizio}
        )
        AND (
          $P{data_fim} IS NULL
          OR DATE(datadimissione) <= $P{data_fim}
        )
        AND (
          $P{categoria_esito} IS NULL
          OR TRIM($P{categoria_esito}) = ''
          OR categoriaesitodimissione = $P{categoria_esito}
        )
      GROUP BY
        nomeesitodimissione,
        codmesitodimissione,
        categoriaesitodimissione
      ORDER BY
        categoriaesitodimissione,
        nomeesitodimissione
    ]]>
  </queryString>

  <field name="nomeesitodimissione" class="java.lang.String"/>
  <field name="codmesitodimissione" class="java.lang.String"/>
  <field name="categoriaesitodimissione" class="java.lang.String"/>
  <field name="qtde" class="java.lang.Long"/>

  <variable name="totalQtde" class="java.lang.Long" calculation="Sum" resetType="Report">
    <variableExpression><![CDATA[$F{qtde}]]></variableExpression>
  </variable>

  <title>
    <band height="95">
      <staticText>
        <reportElement x="0" y="0" width="515" height="24"/>
        <textElement>
          <font fontName="DejaVu Sans" size="16" isBold="true"/>
        </textElement>
        <text>Distribuicao por esito de dimissione</text>
      </staticText>
      <textField pattern="dd/MM/yyyy HH:mm">
        <reportElement x="0" y="30" width="515" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
      </textField>

      <textField isBlankWhenNull="true">
        <reportElement x="0" y="48" width="515" height="14"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA["Periodo: " + ($P{data_inizio} == null ? "(aberto)" : new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{data_inizio})) + " a " + ($P{data_fim} == null ? "(aberto)" : new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{data_fim}))]]></textFieldExpression>
      </textField>

      <textField isBlankWhenNull="true">
        <reportElement x="0" y="63" width="515" height="14"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA["Filtro categoria: " + ($P{categoria_esito} == null || $P{categoria_esito}.trim().isEmpty() ? "Todas" : $P{categoria_esito})]]></textFieldExpression>
      </textField>

      <line>
        <reportElement x="0" y="84" width="515" height="1"/>
        <graphicElement><pen lineWidth="0.7"/></graphicElement>
      </line>
    </band>
  </title>

  <columnHeader>
    <band height="24">
      <line>
        <reportElement x="0" y="0" width="515" height="1"/>
        <graphicElement><pen lineWidth="0.7"/></graphicElement>
      </line>

      <staticText>
        <reportElement x="0" y="2" width="170" height="19"/>
        <textElement>
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Nome Esito</text>
      </staticText>

      <staticText>
        <reportElement x="170" y="2" width="110" height="19"/>
        <textElement>
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Codice</text>
      </staticText>

      <staticText>
        <reportElement x="280" y="2" width="155" height="19"/>
        <textElement>
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Categoria</text>
      </staticText>

      <staticText>
        <reportElement x="435" y="2" width="80" height="19"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Qtde</text>
      </staticText>

      <line>
        <reportElement x="0" y="22" width="515" height="1"/>
        <graphicElement><pen lineWidth="0.7"/></graphicElement>
      </line>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <textField isBlankWhenNull="true">
        <reportElement x="0" y="0" width="170" height="20"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{nomeesitodimissione}]]></textFieldExpression>
      </textField>

      <textField isBlankWhenNull="true">
        <reportElement x="170" y="0" width="110" height="20"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{codmesitodimissione}]]></textFieldExpression>
      </textField>

      <textField isBlankWhenNull="true">
        <reportElement x="280" y="0" width="155" height="20"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{categoriaesitodimissione}]]></textFieldExpression>
      </textField>

      <textField>
        <reportElement x="435" y="0" width="80" height="20"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{qtde}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <pageFooter>
    <band height="30">
      <line>
        <reportElement x="0" y="0" width="515" height="1"/>
        <graphicElement><pen lineWidth="0.5"/></graphicElement>
      </line>

      <textField>
        <reportElement x="0" y="10" width="340" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA["Registros agrupados: " + $V{REPORT_COUNT} + " | Total dimissioni: " + $V{totalQtde}]]></textFieldExpression>
      </textField>

      <textField>
        <reportElement x="410" y="10" width="105" height="15"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA["Pagina " + $V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>

</jasperReport>
