<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" name="IndicadoresTriagemUrgenza" pageWidth="791" pageHeight="612" orientation="Landscape" columnWidth="711" leftMargin="40" rightMargin="40" topMargin="40" bottomMargin="40">
  <parameter name="data_inizio" class="java.util.Date">
    <defaultValueExpression>null</defaultValueExpression>
  </parameter>
  <parameter name="data_fim" class="java.util.Date">
    <defaultValueExpression>null</defaultValueExpression>
  </parameter>
  <parameter name="idps" class="java.lang.String" isForPrompting="false">
    <defaultValueExpression>null</defaultValueExpression>
  </parameter>
  <queryString>SELECT&#xD;
        nomeurgenzaaccettazione,&#xD;
        codmurgenzaaccettazione,&#xD;
        prioritaurgenzaaccettazione,&#xD;
        COUNT(*) AS qtde_acessos&#xD;
      FROM accessops&#xD;
      WHERE 1=1&#xD;
        AND ($P{data_inizio} IS NULL OR dataaccettazione &gt;= $P{data_inizio})&#xD;
        AND ($P{data_fim} IS NULL OR dataaccettazione &lt;= $P{data_fim})&#xD;
        AND ($P{idps} IS NULL OR CAST(idps AS VARCHAR) = $P{idps})&#xD;
      GROUP BY&#xD;
        nomeurgenzaaccettazione,&#xD;
        codmurgenzaaccettazione,&#xD;
        prioritaurgenzaaccettazione&#xD;
      ORDER BY prioritaurgenzaaccettazione</queryString>
  <field name="nomeurgenzaaccettazione" class="java.lang.String"/>
  <field name="codmurgenzaaccettazione" class="java.lang.String"/>
  <field name="prioritaurgenzaaccettazione" class="java.lang.Integer"/>
  <field name="qtde_acessos" class="java.lang.Long"/>
  <variable name="totalAcessos" class="java.lang.Long" calculation="Sum" resetType="Report">
    <variableExpression>$F{qtde_acessos}</variableExpression>
  </variable>
  <title>
    <band height="52">
      <staticText>
        <reportElement x="0" y="0" width="515" height="26" forecolor="#404040"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="13" isBold="true"/>
        </textElement>
        <text>Indicadores de triagem (gravidade / urgenza)</text>
      </staticText>
      <staticText>
        <reportElement x="0" y="36" width="95" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="13" isBold="true"/>
        </textElement>
        <text>Data início:</text>
      </staticText>
      <staticText>
        <reportElement x="205" y="36" width="80" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="13" isBold="true"/>
        </textElement>
        <text>Data fim:</text>
      </staticText>
      <staticText>
        <reportElement x="390" y="36" width="42" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="13" isBold="true"/>
        </textElement>
        <text>ID PS:</text>
      </staticText>
      <textField pattern="dd/MM/yyyy" isBlankWhenNull="true">
        <reportElement x="95" y="36" width="95" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$P{data_inizio}</textFieldExpression>
      </textField>
      <textField pattern="dd/MM/yyyy" isBlankWhenNull="true">
        <reportElement x="282" y="36" width="95" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$P{data_fim}</textFieldExpression>
      </textField>
      <textField>
        <reportElement x="432" y="36" width="83" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$P{idps} != null ? $P{idps} : "Todos"</textFieldExpression>
      </textField>
    </band>
  </title>
  <columnHeader>
    <band height="26">
      <staticText>
        <reportElement x="0" y="0" width="190" height="24" mode="Opaque" backcolor="#F0F0F0" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Gravidade/Urgência</text>
      </staticText>
      <staticText>
        <reportElement x="190" y="0" width="110" height="24" mode="Opaque" backcolor="#F0F0F0" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Código</text>
      </staticText>
      <staticText>
        <reportElement x="300" y="0" width="90" height="24" mode="Opaque" backcolor="#F0F0F0" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Prioridade</text>
      </staticText>
      <staticText>
        <reportElement x="390" y="0" width="125" height="24" mode="Opaque" backcolor="#F0F0F0" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text>Qtde de Acessos</text>
      </staticText>
    </band>
  </columnHeader>
  <detail>
    <band height="22">
      <textField isBlankWhenNull="true">
        <reportElement x="0" y="0" width="190" height="20" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$F{nomeurgenzaaccettazione}</textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="190" y="0" width="110" height="20" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$F{codmurgenzaaccettazione}</textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="300" y="0" width="90" height="20" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$F{prioritaurgenzaaccettazione}</textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="390" y="0" width="125" height="20" forecolor="#404040"/>
        <box>
          <pen lineWidth="0.5"/>
        </box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>$F{qtde_acessos}</textFieldExpression>
      </textField>
      <rectangle>
        <reportElement x="0" y="0" width="711" height="22" mode="Opaque" backcolor="#E5E5E5"/>
      </rectangle>
    </band>
  </detail>
  <pageFooter>
    <band height="24">
      <line>
        <reportElement x="0" y="0" width="515" height="1"/>
      </line>
      <textField>
        <reportElement x="0" y="8" width="280" height="14" forecolor="#404040"/>
        <textElement>
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>"Total de grupos: " + $V{REPORT_COUNT}</textFieldExpression>
      </textField>
      <textField>
        <reportElement x="280" y="8" width="165" height="14" forecolor="#404040"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>"Total acessos: " + $V{totalAcessos}</textFieldExpression>
      </textField>
      <textField>
        <reportElement x="445" y="8" width="70" height="14" forecolor="#404040"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="8" isBold="false"/>
        </textElement>
        <textFieldExpression>"Página " + $V{PAGE_NUMBER}</textFieldExpression>
      </textField>
    </band>
  </pageFooter>
</jasperReport>