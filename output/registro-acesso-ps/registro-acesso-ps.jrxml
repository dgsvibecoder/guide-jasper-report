          <font fontName="DejaVu Sans" size="8" isBold="true"/>
        </textElement>
        <text>Aceit</text>
      </staticText>
      
      <staticText>
        <reportElement x="398" y="5" width="56" height="15" forecolor="#ffffff"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="true"/>
        </textElement>
        <text>Dimiss</text>
      </staticText>
      
      <staticText>
        <reportElement x="455" y="5" width="53" height="15" forecolor="#ffffff"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="true"/>
        </textElement>
        <text>Cod Ext</text>
      </staticText>
      
      <staticText>
        <reportElement x="509" y="5" width="50" height="15" forecolor="#ffffff"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="8" isBold="true"/>
        </textElement>
        <text>Ticket</text>
      </staticText>
    </band>
  </columnHeader>

  <!-- DETAIL -->
  <detail>
    <band height="18">
      <rectangle>
        <reportElement x="0" y="0" width="762" height="18" backcolor="#f0f0f0"/>
