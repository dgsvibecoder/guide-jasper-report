<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  name="RegistroAcessoPS"
  pageWidth="842"
  pageHeight="595"
  orientation="Landscape"
  columnWidth="762"
  leftMargin="40"
  rightMargin="40"
  topMargin="40"
  bottomMargin="40">

  <!-- PARÂMETROS -->
  <parameter name="data_inizio" class="java.util.Date">
    <defaultValueExpression>
      <![CDATA[null]]>
    </defaultValueExpression>
  </parameter>

  <parameter name="data_fim" class="java.util.Date">
    <defaultValueExpression>
      <![CDATA[null]]>
    </defaultValueExpression>
  </parameter>

  <parameter name="idps" class="java.lang.String" isForPrompting="false">
    <defaultValueExpression>
      <![CDATA[null]]>
    </defaultValueExpression>
  </parameter>

  <!-- QUERY PARAMETRIZADA -->
  <queryString>
    <![CDATA[
      SELECT 
        idazienda,
        nomeazienda,
        idps,
        nomeps,
        idaccesso,
        idpaziente,
        datainserimento,
        dataaccettazione,
        datadimissione,
        idcodiceesterno,
        ticket
      FROM accessops
      WHERE 1=1
        AND ($P{data_inizio} IS NULL OR datainserimento >= $P{data_inizio})
        AND ($P{data_fim} IS NULL OR datainserimento <= $P{data_fim})
        AND ($P{idps} IS NULL OR CAST(idps AS VARCHAR) = $P{idps})
      ORDER BY datainserimento DESC
    ]]>
  </queryString>

  <!-- CAMPOS -->
  <field name="idazienda" class="java.lang.String"/>
  <field name="nomeazienda" class="java.lang.String"/>
  <field name="idps" class="java.lang.String"/>
  <field name="nomeps" class="java.lang.String"/>
  <field name="idaccesso" class="java.lang.String"/>
  <field name="idpaziente" class="java.lang.String"/>
  <field name="datainserimento" class="java.sql.Timestamp"/>
  <field name="dataaccettazione" class="java.sql.Timestamp"/>
  <field name="datadimissione" class="java.sql.Timestamp"/>
  <field name="idcodiceesterno" class="java.lang.String"/>
  <field name="ticket" class="java.math.BigDecimal"/>

  <!-- TITLE (CABEÇALHO PRINCIPAL) -->
  <title>
    <band height="80">
      <staticText>
        <reportElement x="0" y="0" width="762" height="35"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="18" isBold="true"/>
        </textElement>
        <text>Registro de Acesso ao Posto de Saúde</text>
      </staticText>
      
      <staticText>
        <reportElement x="0" y="40" width="130" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9" isBold="true"/>
        </textElement>
        <text>Data Início:</text>
      </staticText>
      <textField pattern="dd/MM/yyyy">
        <reportElement x="150" y="40" width="100" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{data_inizio}]]></textFieldExpression>
      </textField>
      
      <staticText>
        <reportElement x="280" y="40" width="100" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9" isBold="true"/>
        </textElement>
        <text>Data Fim:</text>
      </staticText>
      <textField pattern="dd/MM/yyyy">
        <reportElement x="400" y="40" width="100" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{data_fim}]]></textFieldExpression>
      </textField>
      
      <staticText>
        <reportElement x="540" y="40" width="110" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9" isBold="true"/>
        </textElement>
        <text>ID PS (Opcional):</text>
      </staticText>
      <textField>
        <reportElement x="660" y="40" width="100" height="15"/>
        <textElement>
          <font fontName="DejaVu Sans" size="9"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{idps} != null ? $P{idps} : "Todos"]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <!-- COLUMN HEADER -->
  <columnHeader>
    <band height="25">
      <rectangle>
        <reportElement x="0" y="0" width="762" height="25" backcolor="#4472c4"/>
