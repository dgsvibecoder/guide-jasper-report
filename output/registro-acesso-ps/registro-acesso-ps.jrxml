        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{idpaziente}]]></textFieldExpression>
      </textField>
      
      <textField pattern="dd/MM HH:mm">
        <reportElement x="284" y="2" width="56" height="14"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{datainserimento}]]></textFieldExpression>
      </textField>
      
      <textField pattern="dd/MM HH:mm">
        <reportElement x="341" y="2" width="56" height="14"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{dataaccettazione}]]></textFieldExpression>
      </textField>
      
      <textField pattern="dd/MM HH:mm" isBlankWhenNull="true">
        <reportElement x="398" y="2" width="56" height="14"/>
