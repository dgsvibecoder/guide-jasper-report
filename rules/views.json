      "schema": "public",
      "source": "View agregada de vendas com GROUP BY mês",
      "refreshFrequency": "Diária",
      "lastValidated": "2026-03-20",
      
      "validFields": [
        {
          "name": "ano_mes",
          "type": "VARCHAR(7)",
          "label": "Ano-Mês",
          "isKey": true,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "2026-03",
          "format": "YYYY-MM"
        },
        {
          "name": "total_vendas",
          "type": "DECIMAL(15,2)",
          "label": "Total Vendas R$",
          "isKey": false,
          "sortable": true,
          "filterable": false,
          "aggregatable": true,
          "aggregations": ["SUM"],
          "example": 100000.00
        },
        {
          "name": "quantidade_vendas",
          "type": "INT",
          "label": "Quantidade Vendas",
          "isKey": false,
          "sortable": true,
          "filterable": false,
          "aggregatable": true,
          "aggregations": ["SUM"],
          "example": 500
        },
        {
          "name": "ticket_medio",
          "type": "DECIMAL(10,2)",
          "label": "Ticket Médio R$",
          "isKey": false,
          "sortable": true,
          "filterable": false,
          "aggregatable": false,
          "example": 200.00
        },
        {
          "name": "quantidade_vendedores",
          "type": "INT",
          "label": "Qtd Vendedores",
          "isKey": false,
          "sortable": false,
          "filterable": false,
          "aggregatable": false,
          "example": 15
        }
      ]
    }
  },

  "validations": {
    "sqlRules": [
      "Use SELECT explícito: nunca SELECT *",
      "Use WHERE 1=1 como base para condições dinâmicas",
      "Sempre parametrize filtros com $P{paramName}",
      "Inclua ORDER BY para ordenação lógica",
      "Limit 1000 registros por padrão (para performance)",
      "Typecast datas: DATE(campoData) se necessário",
      "Agregações: SUM, AVG, COUNT, MIN, MAX apenas"
    ],
    "jrxmlRules": [
      "Sempre use 4 bandas: title, columnHeader, detail, pageFooter",
      "Parâmetros antes de queryString",
      "Campos devem mapear campos SQL",
      "Tipos Java corretos: String, Date, Integer, BigDecimal",
      "Font padrão: DejaVu Sans",
      "Margins mínimos: 10px em todos lados",
      "Width colunas: 515px total (page width - margins)"
    ]
  },

  "typeMapping": {
    "SQL_JDBC": {
      "DATE": "java.time.LocalDate",
      "TIME": "java.time.LocalTime",
      "DATETIME": "java.time.LocalDateTime",
      "TIMESTAMP": "java.util.Date",
      "INT": "java.lang.Integer",
      "BIGINT": "java.lang.Long",
      "DECIMAL": "java.math.BigDecimal",
      "FLOAT": "java.lang.Double",
      "VARCHAR": "java.lang.String",
      "CHAR": "java.lang.String",
      "TEXT": "java.lang.String",
      "BOOLEAN": "java.lang.Boolean"
    }
  },

  "examples": {
    "simpleQuery": "SELECT data, item_nome, valor_total FROM view_vendas_diarias WHERE 1=1 AND data >= $P{dataInicio} AND data <= $P{dataFim} ORDER BY data DESC",
    
    "aggregateQuery": "SELECT vendedor_nome, SUM(valor_total) as total_vendas, COUNT(*) as quantidade FROM view_vendas_diarias WHERE 1=1 AND data >= $P{dataInicio} AND data <= $P{dataFim} GROUP BY vendedor_nome ORDER BY total_vendas DESC",
    
    "filteredQuery": "SELECT paciente_nome, data_atendimento, procedimento_descricao, valor_procedimento FROM view_pacientes_atendidos WHERE 1=1 AND profissional_id = $P{profissionalId} AND data_atendimento >= $P{dataInicio} ORDER BY data_atendimento DESC"
  },

  "notes": [
    "Versão 1.0 - Inicial com 3 views de exemplo",
    "Para adicionar nova view: 1) Criar VIEW no BD, 2) Adicionar aqui com campos, 3) Validar tipos",
    "Campos sensitive (ex: CPF): marcar com sensitive=true",
    "Atualizar lastValidated regularmente verificando dados no BD"
  ]
}
