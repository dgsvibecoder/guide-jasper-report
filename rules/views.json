        {
          "name": "status_atendimento",
          "type": "VARCHAR(20)",
          "label": "Status",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "allowedValues": ["CONCLUÍDO", "CANCELADO", "NÃO_COMPARECEU"],
          "example": "CONCLUÍDO"
        }
      ]
    },

    "accessops": {
