{
  "version": "1.0",
  "description": "Definição de views disponíveis e campos válidos para geração de relatórios",
  "lastUpdated": "2026-03-30",
  "jasperVersion": "6.2.0",
  
  "datasource": {
    "driver": "org.postgresql.Driver",
    "defaultType": "PostgreSQL",
    "supportedTypes": ["MySQL", "PostgreSQL", "SQL Server", "Oracle"]
  },

  "views": {
    "view_vendas_diarias": {
      "displayName": "Vendas Diárias",
      "description": "Vendas agregadas por item, quantidade, valor e vendedor",
      "schema": "public",
      "source": "Tabela de Vendas + Itens",
      "refreshFrequency": "Diária",
      "lastValidated": "2026-03-15",
      
      "validFields": [
        {
          "name": "data",
          "type": "DATE",
          "label": "Data da Venda",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "2026-03-30"
        },
        {
          "name": "item_nome",
          "type": "VARCHAR(255)",
          "label": "Nome do Item",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "Produto XYZ"
        },
        {
          "name": "item_codigo",
          "type": "VARCHAR(20)",
          "label": "Código Item",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "ITEM-001"
        },
        {
          "name": "quantidade",
          "type": "INT",
          "label": "Quantidade",
          "isKey": false,
          "sortable": false,
          "filterable": false,
          "aggregatable": true,
          "aggregations": ["SUM", "AVG", "COUNT"],
          "example": 100
        },
        {
          "name": "valor_unitario",
          "type": "DECIMAL(10,2)",
          "label": "Valor Unitário R$",
          "isKey": false,
          "sortable": true,
          "filterable": false,
          "aggregatable": true,
          "aggregations": ["SUM", "AVG"],
          "example": 99.99
        },
        {
          "name": "valor_total",
          "type": "DECIMAL(12,2)",
          "label": "Valor Total R$",
          "isKey": false,
          "sortable": true,
          "filterable": false,
          "aggregatable": true,
          "aggregations": ["SUM", "AVG"],
          "example": 9999.00
        },
        {
          "name": "vendedor_nome",
          "type": "VARCHAR(255)",
          "label": "Nome do Vendedor",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "João Silva"
        },
        {
          "name": "vendedor_id",
          "type": "INT",
          "label": "ID Vendedor",
          "isKey": false,
          "sortable": false,
          "filterable": true,
          "aggregatable": false,
          "example": 1001
        },
        {
          "name": "categoria",
          "type": "VARCHAR(100)",
          "label": "Categoria",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "Eletrônicos"
        }
      ]
    },

