  "relationships": {
    "description": "Definição de relacionamentos master/detail permitidos entre views",
    "version": "2.0",
    "lastUpdated": "2026-04-01",
    
    "accessops_medicalEvents": {
      "name": "Acessos com Eventos Médicos",
      "masterView": "accessops",
      "detailView": "view_pacientes_atendidos",
      "relationship": {
        "localKey": "idpaziente",
        "foreignKey": "paciente_id",
        "cardinality": "1:N",
        "validationRequired": true,
        "joinType": "LEFT_OUTER_JOIN",
        "description": "Cada acesso ao PS pode ter múltiplos eventos de atendimento/procedimento"
      },
      "validationRules": {
        "masterKeysRequired": ["idaccesso", "idpaziente"],
        "detailKeysRequired": ["paciente_id"],
        "parameterBinding": {
          "pacienteId": "idpaziente"
        }
      },
      "contextMaster": "Registro de entrada do paciente no Posto de Saúde",
      "contextDetail": "Procedimentos e atendimentos realizados"
    },
    
    "vendedores_vendas": {
      "name": "Vendedor com Itens de Venda",
      "masterView": "view_vendas_diarias",
      "detailView": "view_vendas_diarias",
      "relationship": {
        "localKey": "vendedor_id",
        "foreignKey": "vendedor_id",
        "groupByMaster": "vendedor_id",
        "cardinality": "1:N",
        "validationRequired": true,
        "joinType": "INNER_JOIN",
        "description": "Agregação: resumo por vendedor com detalhe de cada venda"
      },
      "validationRules": {
        "masterKeysRequired": ["vendedor_id", "vendedor_nome"],
        "detailKeysRequired": ["vendedor_id", "data", "item_nome"],
        "masterGroupingFields": ["vendedor_id", "vendedor_nome"],
        "detailGroupingFields": ["data", "item_nome", "categoria"],
        "parameterBinding": {
          "vendedorId": "vendedor_id"
        }
      },
      "contextMaster": "Totalizador de vendas por vendedor",
      "contextDetail": "Itens vendidos por dia/vendedor"
    },
    
    "pacientes_triagem": {
      "name": "Pacientes Atendidos com Triagem",
      "masterView": "paziente",
      "detailView": "view_pacientes_atendidos",
      "relationship": {
        "localKey": "idpaziente",
        "foreignKey": "paciente_id",
        "cardinality": "1:N",
        "validationRequired": true,
        "joinType": "LEFT_OUTER_JOIN",
        "description": "Cada paciente cadastro pode ter múltiplos atendimentos"
