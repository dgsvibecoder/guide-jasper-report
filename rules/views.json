          "label": "ID Profissional",
          "isKey": false,
          "sortable": false,
          "filterable": true,
          "aggregatable": false,
          "example": 2001
        },
        {
          "name": "profissional_nome",
          "type": "VARCHAR(255)",
          "label": "Nome do Profissional",
          "isKey": false,
          "sortable": true,
          "filterable": true,
          "aggregatable": false,
          "example": "Dr. João Silva"
        },
        {
          "name": "valor_procedimento",
          "type": "DECIMAL(10,2)",
          "label": "Valor do Procedimento R$",
          "isKey": false,
          "sortable": true,
          "filterable": false,
